APP_ENV=development
REDIS_URL=redis://localhost:6379/0
BROWSER_PROVIDER_MODE=dry_run
BROWSER_MAX_JOBS_PER_RUN=10
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_ACTION_TIMEOUT_MS=10000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=20000
PLAYWRIGHT_DOWNLOAD_TIMEOUT_MS=30000
PLAYWRIGHT_PROFILE_ROOT=browser-profiles
PLAYWRIGHT_DOWNLOAD_ROOT=storage/downloads
ELEVENLABS_PROFILE_NAME=elevenlabs-default
FLOW_PROFILE_NAME=flow-default
ELEVENLABS_WORKSPACE_URL=https://elevenlabs.io/app
FLOW_WORKSPACE_URL=https://labs.google/fx/tools/flow
